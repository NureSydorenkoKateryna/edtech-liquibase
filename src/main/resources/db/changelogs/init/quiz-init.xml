<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-quiz-table" author="druchek">
        <createTable tableName="quiz">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_quiz" nullable="false" />
            </column>
            <column name="instructions" type="VARCHAR(MAX)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'quiz', 'SYSTEM', 'druchek', 1, 'testing_service',
                    'Creation of quiz table.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('quiz')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'quiz';</sql>
            <dropTable tableName="quiz"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
