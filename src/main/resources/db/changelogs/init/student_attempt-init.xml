<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-student_attempt-table" author="derkach">
        <createTable tableName="student_attempt">
            <column name="student_attempt_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_student_attempt" />
            </column>
            <column name="enrollment_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="task_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="started_at" type="DATETIME" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="submitted_at" type="DATETIME">
                <constraints nullable="true"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="student_attempt"
                                 baseColumnNames="enrollment_id"
                                 constraintName="fk_student_attempt_enrollment"
                                 referencedTableName="enrollment"
                                 referencedColumnNames="id" />

        <addForeignKeyConstraint baseTableName="student_attempt"
                                 baseColumnNames="task_id"
                                 constraintName="fk_student_attempt_task"
                                 referencedTableName="task"
                                 referencedColumnNames="id" />

        <createIndex tableName="student_attempt" indexName="idx_student_attempt_enrollment_id_task_id">
            <column name="enrollment_id"/>
            <column name="task_id"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'student_attempt', 'SYSTEM', 'derkach', 1, 'testing_service',
                    'Creation of student_attempt table.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('student_attempt')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'student_attempt';</sql>
            <dropTable tableName="student_attempt"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
