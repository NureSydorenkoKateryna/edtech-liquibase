<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-user_role-table" author="derkach">
        <createTable tableName="user_role">
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_role" />
            </column>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_user_role" />
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="user_role"
                                 baseColumnNames="user_id"
                                 constraintName="fk_user_role_user_id"
                                 referencedTableName="user"
                                 referencedColumnNames="id" />

        <addForeignKeyConstraint baseTableName="user_role"
                                 baseColumnNames="role_id"
                                 constraintName="fk_user_role_role_id"
                                 referencedTableName="role"
                                 referencedColumnNames="id" />

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'user_role', 'SYSTEM', 'derkach', 1, 'user_service',
                    'Creation of user_role table.',
                    (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('user_role')),
                    SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'user_role';</sql>
            <dropTable tableName="user_role"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
