<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003-create-enrollment-table" author="sydorenko">
        <createTable tableName="enrollment">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_enrollment" nullable="false" />
            </column>
            <column name="course_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" />
            </column>
            <column name="enrolled_at" type="DATETIME" defaultValueComputed="GETDATE()">
                <constraints nullable="false"/>
            </column>
            <column name="completed_at" type="DATETIME"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="enrollment"
                                 baseColumnNames="course_id"
                                 constraintName="fk_enrollment_course"
                                 referencedTableName="course"
                                 referencedColumnNames="id" />
        <addForeignKeyConstraint baseTableName="enrollment"
                                 baseColumnNames="user_id"
                                 constraintName="fk_enrollment_user"
                                 referencedTableName="user"
                                 referencedColumnNames="id" />

        <addUniqueConstraint tableName="enrollment"
                             columnNames="course_id, user_id"
                             constraintName="uk_enrollment_course_id_user_id"/>

        <createIndex tableName="enrollment" indexName="idx_enrollment_user_id_enrolled_at">
            <column name="user_id"/>
            <column name="enrolled_at"/>
        </createIndex>

        <sql>
            INSERT INTO dbo.tables (db_, name, type, author, version, service, description, column_count, created_at, last_update_at)
            VALUES ('liquibase_lab', 'enrollment', 'SYSTEM', 'sydorenko', 1, 'student_progress_service',
            'Tracks user enrollments in courses.',
            (SELECT COUNT(*) FROM sys.columns WHERE object_id = OBJECT_ID('enrollment')),
            SYSUTCDATETIME(), NULL);
        </sql>

        <rollback>
            <sql>DELETE FROM dbo.tables WHERE name = 'enrollment';</sql>
            <dropTable tableName="enrollment"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
